<% layout('/layouts/boilerplate.ejs') %>

<div class="row mt-3">
  <div class="col-10 col-sm-9 col-lg-6">
    <h2>
      &nbsp;&nbsp;Signup for
      <span
        style="
          color: #3ea171;
          font-family:
            &quot;Trebuchet MS&quot;, &quot;Lucida Sans Unicode&quot;,
            &quot;Lucida Grande&quot;, &quot;Lucida Sans&quot;, Arial,
            sans-serif;
        "
        >Sync Rides</span
      >
    </h2>
    <form
      action="/signup"
      method="POST"
      class="needs-validation mt-3 ms-3"
      novalidate
    >
      <div class="mb-3 mt-5 form-floating">
        <input
          name="fullname"
          placeholder="Enter Full Name"
          type="text"
          required
          class="form-control"
        /><label for="fullname" class="form-label mb-0">Full Name</label>
        <div class="invalid-feedback">Full name is required</div>
      </div>
      <div class="mb-3 form-floating">
        <input
          name="email"
          placeholder="Enter your Email"
          type="email"
          required
          class="form-control"
        />
        <div class="invalid-feedback">Email address is required</div>
        <label for="email" class="form-label mb-0">Email</label>
      </div>
      <div class="mb-3 form-floating">
        <input
          name="phone"
          placeholder="Enter phone number"
          type="tel"
          required
          class="form-control"
        />
        <div class="invalid-feedback">Phone number is required</div>
        <label for="phone" class="form-label mb-0">Phone</label>
      </div>
      <div class="form-floating">
        <input
          name="password"
          placeholder="Enter your Password"
          type="password"
          required
          class="form-control"
        />
        <div class="invalid-feedback">Password is required</div>
        <label for="password" class="form-label mb-0">Password</label>
      </div>

      <select
        name="role"
        class="form-select mt-3"
        aria-label="Role select"
        required
        style="height: 47px"
      >
        <option value="" disabled selected hidden>Select role</option>
        <option value="driver">Driver</option>
        <option value="rider">Rider</option>
      </select>
      <div class="invalid-feedback">Role is required</div>
      <div id="driver-fields" class="mt-3">
        <div class="mb-3">
          <input
            name="vehicle_model"
            placeholder="Vehicle model (drivers only)"
            type="text"
            class="form-control"
          />
        </div>
        <div>
          <input
            name="seats"
            placeholder="Available seats (drivers only)"
            type="number"
            min="1"
            max="8"
            class="form-control"
          />
        </div>
      </div>

      <br />
      <button class="btn btn-success" style="width: 100%; border: none">
        Signup
      </button>
    </form>
    <hr />
    <div class="ms-3 f-info-link">
      Already have an account?
      <a href="/login" style="font-weight: 600; padding-left: 2px !important"
        >Login</a
      >
    </div>
  </div>
</div>
