<% layout('/layouts/boilerplate.ejs') %>

<link rel="stylesheet" href="/css/booking.css" />

<div class="booking-page-container">

  <div class="page-header">
    <h1>My Bookings</h1>
    <p>View and manage all your ride bookings in one place.</p>
  </div>

  <div class="booking-layout">

    <div class="bookings-main">
      <div class="bookings-scroll">

        <!-- SCHEDULED TRIPS -->

        <% if (scheduledTrips.length === 0) { %>
          <p style="text-align:center; opacity:0.7;">
            No scheduled trips
          </p>
        <% } %>

        <% scheduledTrips.forEach(trip => { %>

          <div class="booking-card">

            <div class="location-icon green">
              <i class="fas fa-map-marker-alt"></i>
            </div>

            <div class="route-section">
              <h3><%= trip.pickup %></h3>
              <p><%= trip.destination %></p>

              <div class="meta-row">
                <span>
                  <i class="fas fa-calendar"></i>
                  <%= new Date(trip.time).toDateString() %>
                </span>

                <span>
                  <i class="fas fa-clock"></i>
                  <%= new Date(trip.time)
                        .toLocaleTimeString([], {
                          hour: '2-digit',
                          minute: '2-digit'
                        })
                  %>
                </span>
              </div>
            </div>

            <div class="driver-section">
              <h4>
                <%= trip.driver.fullname %>
              </h4>

              <p>
                Seats Left: <%= trip.seats %>
              </p>
            </div>

            <div class="fare-section">
              <h2>₹ --</h2>
              <span>Total Fare</span>
            </div>

            <div class="action-section">
              <span class="status upcoming">Upcoming</span>
            </div>

          </div>

        <% }) %>

        <!-- COMPLETED TRIPS -->

        <% completedTrips.forEach(trip => { %>

          <div class="booking-card">

            <div class="location-icon blue">
              <i class="fas fa-map-marker-alt"></i>
            </div>

            <div class="route-section">
              <h3><%= trip.pickup %></h3>
              <p><%= trip.destination %></p>

              <div class="meta-row">
                <span>
                  <i class="fas fa-calendar"></i>
                  <%= new Date(trip.time).toDateString() %>
                </span>

                <span>
                  <i class="fas fa-clock"></i>
                  <%= new Date(trip.time)
                        .toLocaleTimeString([], {
                          hour: '2-digit',
                          minute: '2-digit'
                        })
                  %>
                </span>
              </div>
            </div>

            <div class="driver-section">
              <h4>
                <%= trip.driver.fullname %>
              </h4>

              <p>
                Seats Left: <%= trip.seats %>
              </p>
            </div>

            <div class="fare-section">
              <h2>₹ --</h2>
              <span>Total Fare</span>
            </div>

            <div class="action-section">
              <span class="status completed">Completed</span>
            </div>

          </div>

        <% }) %>

        <!-- CANCELLED TRIPS -->

        <% cancelledTrips.forEach(trip => { %>

          <div class="booking-card">

            <div class="location-icon red">
              <i class="fas fa-map-marker-alt"></i>
            </div>

            <div class="route-section">
              <h3><%= trip.pickup %></h3>
              <p><%= trip.destination %></p>

              <div class="meta-row">
                <span>
                  <i class="fas fa-calendar"></i>
                  <%= new Date(trip.time).toDateString() %>
                </span>

                <span>
                  <i class="fas fa-clock"></i>
                  <%= new Date(trip.time)
                        .toLocaleTimeString([], {
                          hour: '2-digit',
                          minute: '2-digit'
                        })
                  %>
                </span>
              </div>
            </div>

            <div class="driver-section">
              <h4>
                <%= trip.driver.fullname %>
              </h4>

              <p>
                Seats Left: <%= trip.seats %>
              </p>
            </div>

            <div class="fare-section">
              <h2>₹ --</h2>
              <span>Total Fare</span>
            </div>

            <div class="action-section">
              <span class="status cancelled">Cancelled</span>
            </div>

          </div>

        <% }) %>

      </div>
    </div>

    <!-- RIGHT SIDEBAR -->

    <aside class="booking-sidebar">

      <div class="sidebar-card">

        <h3>Booking Summary</h3>

        <div class="summary-item">
          <span>Total Bookings</span>
          <strong>
            <%= scheduledTrips.length + completedTrips.length + cancelledTrips.length %>
          </strong>
        </div>

        <div class="summary-item">
          <span>Upcoming</span>
          <strong><%= scheduledTrips.length %></strong>
        </div>

        <div class="summary-item">
          <span>Completed</span>
          <strong><%= completedTrips.length %></strong>
        </div>

        <div class="summary-item">
          <span>Cancelled</span>
          <strong><%= cancelledTrips.length %></strong>
        </div>

      </div>

      <div class="sidebar-card">
        <h3>Looking for a new ride?</h3>
        <p>Find verified drivers and book your next trip.</p>
        <a href="/dashboard" class="btn-find-ride">
          Find a Ride
        </a>
      </div>

    </aside>

  </div>

</div>
