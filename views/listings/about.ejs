<% layout('/layouts/boilerplate.ejs') %>

<div class="about-page">
  <section class="about-hero">
    <div class="about-copy">
      <p class="about-eyebrow">About Sync Rides</p>
      <h2>Safe, smart, and sustainable ride-sharing for every journey.</h2>
      <p>
        Sync Rides is built to make your commute easier, more affordable, and
        more trusted. We connect local drivers and riders with transparent
        pricing, live updates, and a community-first experience.
      </p>
      <div class="about-actions">
        <a href="/signup" class="btn1 about-btn">Become a Driver</a>
        <a href="/login" class="btn2 about-btn">Book a Ride</a>
      </div>
    </div>

    <div class="about-hero-cards">
      <article class="about-card">
        <span class="about-card-icon material-icons">directions_car</span>
        <h3>Reliable Rides</h3>
        <p>
          Get on-demand visibility, easy route planning, and dependable driver
          support across every trip.
        </p>
      </article>
      <article class="about-card">
        <span class="about-card-icon material-icons">shield</span>
        <h3>Trusted Community</h3>
        <p>
          Verified drivers, transparent reviews, and a platform designed to keep
          every journey safe.
        </p>
      </article>
      <article class="about-card">
        <span class="about-card-icon material-icons">eco</span>
        <h3>Eco-Friendly Travel</h3>
        <p>
          Carpool smarter to reduce traffic, lower commute costs, and make a
          positive impact on the environment.
        </p>
      </article>
    </div>
  </section>

  <section class="about-values">
    <div class="value-block">
      <h2>Our Mission</h2>
      <p>
        To simplify daily travel by making shared rides easy, affordable, and
        accessible for every community.
      </p>
    </div>
    <div class="value-block">
      <h2>Our Vision</h2>
      <p>
        To build the most trusted and connected carpool network where every trip
        feels smarter and safer.
      </p>
    </div>
    <div class="value-block">
      <h2>Our Promise</h2>
      <p>
        Clear pricing, fast support, and a driver-first app experience that
        keeps riders and drivers moving together.
      </p>
    </div>
  </section>

  <section class="about-cta">
    <h2>Ready to ride with Sync Rides?</h2>
    <p>
      Join our growing community today and experience the better way to share
      every commute.
    </p>
    <a href="/signup" class="btn1">Get Started</a>
  </section>
</div>
