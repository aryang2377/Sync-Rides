<% layout('/layouts/boilerplate.ejs') %>

<main class="about-container">

  <!-- HERO -->

  <section class="about-hero">

    <div class="about-badge">
      ✨ About Sync Rides
    </div>

    <h1>
      Safe, Smart & Sustainable
      <br>
      Ride-Sharing for Every Journey
    </h1>

    <p class="tagline">
      Sync Rides is built to make your commute easier, more affordable,
      and more trusted. We connect local drivers and riders with
      transparent pricing, live updates, and a community-first experience.
    </p>

  </section>



  <!-- MISSION / VISION / PROMISE -->

  <section class="mission-vision-row">

    <div class="mvp-card">
      <div class="mvp-icon">🎯</div>

      <h3>Our Mission</h3>

      <p>
        To simplify daily travel by making shared rides
        easy, affordable and accessible for every community.
      </p>
    </div>


    <div class="mvp-card">
      <div class="mvp-icon">🌍</div>

      <h3>Our Vision</h3>

      <p>
        To build the most trusted and connected carpool network
        where every trip feels smarter and safer.
      </p>
    </div>


    <div class="mvp-card">
      <div class="mvp-icon">⚡</div>

      <h3>Our Promise</h3>

      <p>
        Clear pricing, fast support, and a driver-first app
        experience that keeps riders and drivers moving together.
      </p>
    </div>

  </section>



  <!-- WHY CHOOSE -->

  <section class="why-section">

    <h2 class="section-title">
      Why Choose Sync Rides?
    </h2>

    <div class="features-grid">

      <div class="feature-item">
        <div class="feature-icon">🚘</div>

        <h4>Reliable Rides</h4>

        <p>
          Get on-demand visibility, easy route planning,
          and dependable driver support across every trip.
        </p>
      </div>


      <div class="feature-item">
        <div class="feature-icon">🤝</div>

        <h4>Trusted Community</h4>

        <p>
          Verified drivers, transparent reviews,
          and a secure platform designed to keep every journey safe.
        </p>
      </div>


      <div class="feature-item">
        <div class="feature-icon">🌱</div>

        <h4>Eco-Friendly Travel</h4>

        <p>
          Carpool smarter to reduce your carbon footprint
          and contribute to a cleaner environment.
        </p>
      </div>

    </div>

  </section>



  <!-- STATS -->

  <section class="promise-stats">

    <div class="stat">
      <div class="stat-number">
        <%= locals.stats ? stats.activeRiders : '10k+' %>
      </div>

      <div class="stat-label">
        Active riders monthly
      </div>
    </div>


    <div class="stat">
      <div class="stat-number">
        <%= locals.stats ? stats.satisfactionRate : '98%' %>
      </div>

      <div class="stat-label">
        Satisfaction rate
      </div>
    </div>


    <div class="stat">
      <div class="stat-number">
        <%= locals.stats ? stats.co2Saved : '🌿 2.4k kg' %>
      </div>

      <div class="stat-label">
        CO₂ saved together
      </div>
    </div>


    <div class="stat">
      <div class="stat-number">
        <%= locals.stats ? stats.supportStatus : '24/7' %>
      </div>

      <div class="stat-label">
        Support & Safety
      </div>
    </div>

  </section>



  <!-- STORY -->

  <section class="story-block">

    <h2>
      📍 Built for real connections
    </h2>

    <p>
      Sync Rides started with a simple belief:
      commuting shouldn't feel lonely or expensive.
      We're blending technology with human trust —
      giving neighbors, professionals, and students
      a seamless way to share rides.
    </p>

    <div class="cta-group">

      <a href="/become-driver" class="btn-primary">
        🚖 Become a Driver
      </a>

      <a href="/book-ride" class="btn-secondary">
        📱 Book a Ride
      </a>

    </div>

  </section>



  <!-- DIVIDER -->

  <hr>



  <!-- PROMISE LINE -->

  <section class="promise-highlight">

    <p>
      ⚡
      <span class="highlight">
        Clear pricing, fast support, and a driver-first experience
      </span>
      — we keep riders and drivers moving together,
      with full transparency and community care.
    </p>

  </section>



  <!-- READY CTA -->

  <section class="ready-section">

    <h2 class="ready-title">
      Ready to ride with Sync Rides?
    </h2>

    <p class="ready-text">
      Join our growing community today and experience
      the better way to share every commute.
    </p>



    <% if (locals.user && user.isLoggedIn) { %>

      <p class="welcome-text">
        Welcome back,
        <%= user.name || 'Rider' %> 🚀
      </p>

      <a href="/dashboard" class="btn-primary">
        Go to Dashboard →
      </a>

    <% } else { %>

      <a href="/signup" class="btn-primary">
        Get Started →
      </a>

    <% } %>

  </section>



  <!-- FOOTER NOTE -->

  <div class="about-footer">

    Sync Rides — safe, smart, sustainable mobility for every journey.

  </div>

</main>