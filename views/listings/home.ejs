<% layout('/layouts/boilerplate.ejs') %>


<div class="front">
  <div class="texx">
    <h1 class="head">Carpool smarter, save time and money</h1>

    <p class="cap">
      Find nearby drivers or riders, plan group journeys, and split costs with
      easy scheduling.
    </p>

    <div class="buttons">
      <a href="/signup" class="btn1">Find a Ride</a>
      <a href="/login" class="btn2">Offer a Ride</a>
    </div>
  </div>

  <div class="rightside">
    <div class="chart-card">
      <div class="chart-top">
        <span>Matched carpools · Jan–Dec 2025</span>
        <span class="yoy">+68% YOY</span>
      </div>
      <svg
        viewBox="0 0 340 140"
        preserveAspectRatio="none"
        style="width: 100%; height: 120px; display: block"
      >
        <defs>
          <linearGradient id="cg1" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#1d9e75" stop-opacity="0.4" />
            <stop offset="100%" stop-color="#1d9e75" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path
          d="M0 130 L57 120 L113 105 L170 80 L226 45 L283 15 L340 0 L340 140 L0 140Z"
          fill="url(#cg1)"
        />
        <polyline
          fill="none"
          stroke="#5dcaa5"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          points="0,130 57,120 113,105 170,80 226,45 283,15 340,0"
        />
        <circle cx="340" cy="0" r="4" fill="#5dcaa5" />
      </svg>
      <div class="chart-stats">
        <div><strong>2.3K+</strong><span>Rides matched</span></div>
        <div><strong>5.6K+</strong><span>Active users</span></div>
        <div><strong>99.5%</strong><span>On-time pickup</span></div>
      </div>
    </div>
  </div>
</div>

<div class="back">
  <div class="graph">
    <img
      src="/img/graph.png"
      class="graph-i"
      loading="lazy"
      alt="Analytics graph"
    />
  </div>

  <div class="right_sidetext">
    <h3 class="head2">Real-time ride matching<br />for commute convenience</h3>
    <p class="cap2">
      Optimize routes, connect with verified drivers, and reduce your commute
      cost with real-time carpool insights. Sync Rides helps users find a match
      fast and share trips securely.
    </p>
    <ul class="features_right">
      <li>&nbsp;&nbsp;Instant ride matching based on route and time</li>
      <li>&nbsp;&nbsp;Driver/rider preferences and availability</li>
      <li>&nbsp;&nbsp;Fair fare splitting and in-app confirmations</li>
      <li>&nbsp;&nbsp;Ratings, history, and trust building features</li>
    </ul>
  </div>
</div>
