<% layout('/layouts/boilerplate.ejs') %>
<link rel="stylesheet" href="/css/driver_dashboard.css" />

<div class="driver-dashboard-wrapper">
  <div class="dashboard-content">
    <!-- HEADER -->
    <header class="driver-header">
      <div class="driver-welcome">
        <p style="font-size: x-large">
          Booked Rides
        </p>
      </div>
    </header>

    <!-- OFFERED RIDES -->
    <section class="glass-card offered-rides-section">
      <div class="card-header">
        <i class="fas fa-car"></i>
        <h3>Booked Rides</h3>
      </div>

      <% if (!rides || rides.length === 0) { %>
        <p class="card-desc">You haven't offered any rides yet.</p>
        <p>Debug: <%= rides ? rides.length : 'undefined' %> rides found</p>
      <% } else { %>
        <div class="rides-list">
          <% rides.forEach((ride) => { %>
            <div class="ride-item">
              <div class="ride-info">
                <h4><%= ride.origin.address.toUpperCase() %> ➔ <%= ride.destination.address.toUpperCase() %></h4>
                <p>
                  <i class="fas fa-calendar"></i>
                  <%= new Date(ride.departure_time).toLocaleDateString() %>
                  <i class="fas fa-clock"></i>
                  <%= new Date(ride.departure_time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                </p>
                <p>
                  <i class="fas fa-users"></i>
                  <%= ride.available_seats %> / <%= ride.total_seats %> seats available
                </p>
                <% const rideBookings = bookingsByRide[ride._id] || []; %>
                <% if (rideBookings.length > 0) { %>
                  <div class="bookings-summary">
                    <p><i class="fas fa-ticket-alt"></i> <%= rideBookings.length %> booking<%= rideBookings.length > 1 ? 's' : '' %></p>
                  </div>
                <% } %>
              </div>
              <div class="ride-actions">
                <a href="/rides/<%= ride._id %>/edit" class="btn-edit">
                  <i class="fas fa-edit"></i>
                  Edit
                </a>
                <form action="/rides/<%= ride._id %>?_method=DELETE" method="POST" class="delete-form" onsubmit="return confirm('Are you sure you want to delete this ride?')">
                  <button type="submit" class="btn-delete">
                    <i class="fas fa-trash"></i>
                    Delete
                  </button>
                </form>
              </div>
            </div>
            
            <% if (rideBookings.length > 0) { %>
              <div class="ride-bookings">
                <h5>Passengers Booked:</h5>
                <% rideBookings.forEach((booking) => { %>
                  <div class="booking-detail">
                    <div class="passenger-info">
                      <span class="passenger-name"><%= booking.rider?.fullname || 'Unknown' %></span>
                      <% if (booking.rider?.phone) { %>
                        <span class="passenger-phone"><%= booking.rider.phone %></span>
                      <% } %>
                    </div>
                    <div class="booking-status">
                      <span class="status <%= booking.status %>"><%= booking.status %></span>
                      <span class="booking-seats"><%= booking.seats_booked %> seat<%= booking.seats_booked > 1 ? 's' : '' %></span>
                    </div>
                    <div class="booking-actions">
                      <% if (booking.status === 'pending') { %>
                        <form action="/bookings/<%= booking._id %>/confirm" method="POST" style="display: inline;">
                          <button type="submit" class="btn-confirm">Confirm</button>
                        </form>
                        <form action="/bookings/<%= booking._id %>/cancel" method="POST" style="display: inline;">
                          <button type="submit" class="btn-cancel-booking">Cancel</button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } %>
          <% }); %>
        </div>
      <% } %>
    </section>
  </div>
</div>