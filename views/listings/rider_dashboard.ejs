<% layout('/layouts/boilerplate.ejs') %>

<link rel="stylesheet" href="/css/rider_dashboard.css" />

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/dark.css" />

<div class="rider-dashboard-container">
  <div class="dashboard-wrapper">

    <!-- HEADER -->

    <header class="dashboard-header">
      <div class="welcome-msg">
        <h2>
          Welcome Back,
          <span class="gold-text">
            <%= user && user.fullname ? user.fullname : 'Rider' %>
          </span>
        </h2>
      </div>

      <div class="live-indicator">
        <span class="dot"></span> Live Refreshing
      </div>
    </header>

    <!-- KPI SECTION -->

    <section class="kpi-grid">

      <div class="glass-card kpi-card">
        <span class="kpi-label">Total Trips</span>
        <span class="large-number">
          <%= totalTrips || 0 %>
        </span>
        <button class="kpi-btn" onclick="location.href='/my-bookings'">
          View Bookings
        </button>
      </div>

      <div class="glass-card kpi-card">
        <span class="kpi-label">Upcoming</span>
        <span class="large-number">
          <%= upcomingTrips || 0 %>
        </span>
        <button class="kpi-btn" onclick="location.href='/my-bookings'">
          View All
        </button>
      </div>

      <div class="glass-card kpi-card">
        <span class="kpi-label">Next Ride</span>
        <span class="large-number">
          <%= nextRide
              ? new Date(nextRide.time).toLocaleTimeString([], {
                  hour: '2-digit',
                  minute: '2-digit'
                })
              : "None"
          %>
        </span>
        <p class="sub-text">
          <%= nextRide
              ? new Date(nextRide.time).toDateString()
              : "No upcoming ride"
          %>
        </p>
      </div>

      <div class="glass-card kpi-card eco-card">
        <span class="kpi-label">Eco Impact</span>
        <span class="large-number" style="color:#00ff88">
          12.4 kg
        </span>
        <p class="sub-text">CO₂ Emissions Saved 🌿</p>
      </div>

    </section>

    <!-- ACTION GRID -->

    <div class="action-grid">

      <!-- Schedule Trip -->

      <section class="glass-card">

        <h3>
          <i class="fas fa-calendar-plus"></i>
          Schedule Your Trip
        </h3>

        <form action="/trips" method="POST" class="dashboard-form">

          <div class="form-group">
            <label>Pickup Location</label>
            <input
              type="text"
              name="pickup"
              placeholder="e.g., Delhi Metro Station"
              required
            />
          </div>

          <div class="form-group">
            <label>Drop-off Destination</label>
            <input
              type="text"
              name="destination"
              placeholder="e.g., Office"
              required
            />
          </div>

          <div class="form-group">
            <label>Departure Date & Time</label>
            <input
              type="text"
              id="departureDate"
              name="time"
              placeholder="Select date and time"
              required
            />
          </div>

          <button type="submit" class="btn-primary-gold">
            Post Ride Request
          </button>

        </form>

      </section>

      <!-- Nearby Peer Rides -->

      <section class="glass-card">

        <h3>
          <i class="fas fa-users"></i>
          Available Rides
        </h3>

        <div class="ride-feed">

          <% if (!trips || trips.length === 0) { %>

            <p style="text-align:center; opacity:0.7;">
              No rides available yet
            </p>

          <% } %>

          <% if (trips && trips.length > 0) { %>

            <% trips.forEach(trip => { %>

              <div class="ride-card">

                <div class="ride-info">

                  <strong>
                    <%= trip.driver && trip.driver.fullname
                        ? trip.driver.fullname
                        : 'Driver'
                    %>
                  </strong>

                  <span>
                    <%= trip.pickup %>
                    →
                    <%= trip.destination %>
                  </span>

                  <span>
                    <%= new Date(trip.time)
                          .toLocaleTimeString([], {
                            hour: '2-digit',
                            minute: '2-digit'
                          })
                    %>
                  </span>

                  <span class="seats-left">
                    ● <%= trip.seats %> Seats Left
                  </span>

                </div>

                <form action="/join/<%= trip._id %>" method="POST">

                  <button class="btn-join-outline">
                    JOIN RIDE
                  </button>

                </form>

              </div>

            <% }) %>

          <% } %>

        </div>

      </section>

    </div>

    <!-- MAP -->

    <div class="map-container glass-card">
      <div id="map"></div>
    </div>

  </div>
</div>

<script>
  window.mapToken = "<%= mapToken || '' %>";
</script>

<script src="/js/map.js"></script>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
  flatpickr("#departureDate", {
    enableTime: true,
    dateFormat: "Y-m-d H:i",
    minDate: "today",
    time_24hr: true
  });
</script>
